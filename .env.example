# Server
PORT=3200
NODE_ENV=production

# MySQL
DB_HOST=localhost
DB_USER=notary
DB_PASSWORD=
DB_NAME=kaspa_notary

# Session / JWT
SESSION_SECRET=change-this-to-random-64-char-string

# File storage (outside web root)
DOCUMENTS_DIR=/var/www/notary/documents

# Keystone transaction API
KEYSTONE_API_URL=https://your-keystone-server.com
KEYSTONE_API_KEY=
KEYSTONE_NOTARY_WALLET_ID=

# Notary fee (KAS) — covers all 3 transactions
NOTARY_FEE_KAS=5

# KasperoPay
KASPERO_PAY_MERCHANT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kaspanotary.com

# Domain
APP_URL=https://kaspanotary.com
